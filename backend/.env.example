# ============================================================================
# Igisubizo Muhinzi - Environment Configuration Example
# ============================================================================
# Copy this file to .env and update values for your environment

# ============================================================================
# PROJECT CONFIGURATION
# ============================================================================
ENVIRONMENT=development
PROJECT_NAME=Igisubizo Muhinzi API
VERSION=1.0.0

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Comma-separated list of allowed origins
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8081

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Log format: json or text
LOG_FORMAT=json

# ============================================================================
# MODEL CONFIGURATION
# ============================================================================
# Path to trained model file
MODEL_PATH=models/crop_model_seasonal.pkl
# Path to label encoders file
ENCODER_PATH=models/encoders_seasonal.pkl
# Confidence threshold for predictions (0.0 to 1.0)
CONFIDENCE_THRESHOLD=0.3

# ============================================================================
# DATABASE CONFIGURATION (Optional - Phase 2)
# ============================================================================
# PostgreSQL connection string
# DATABASE_URL=postgresql://user:password@localhost:5432/igisubizo

# ============================================================================
# CACHE CONFIGURATION (Optional - Phase 2)
# ============================================================================
# Redis connection string
# CACHE_URL=redis://localhost:6379/0

# ============================================================================
# API SECURITY CONFIGURATION (Optional - Phase 2)
# ============================================================================
# Secret key for API key generation
# API_KEY_SECRET=your-secret-key-here
# Rate limit: requests per minute per client
RATE_LIMIT_PER_MINUTE=100

# ============================================================================
# AI SERVICE CONFIGURATION
# ============================================================================
# Groq API key for AI-powered crop interpretation
GROQ_API_KEY=your-groq-api-key-here

# ============================================================================
# REQUEST CONFIGURATION
# ============================================================================
# Request timeout in seconds
REQUEST_TIMEOUT_SECONDS=30
# Maximum request body size in KB
MAX_REQUEST_SIZE_KB=10
